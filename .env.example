# ── Ollama ────────────────────────────────────────────────────────────────────
# URL of your local Ollama instance
OLLAMA_BASE_URL=http://localhost:11434

# Extraction agents (JD parser, CV extractor, signal enricher)
# Recommended: qwen2.5:7b  |  Minimum VRAM: ~6 GB
SMALL_MODEL=qwen2.5:7b

# Judge + pool calibrator (reasoning-heavy phases 4-5)
# Recommended: llama3.3:70b  |  Minimum VRAM: ~48 GB (or use Q4 quant)
LARGE_MODEL=llama3.3:70b

# ── LLM tuning ────────────────────────────────────────────────────────────────
# 0.0 = fully deterministic; keep extraction at 0 for reproducibility
EXTRACTION_TEMPERATURE=0.0

# Slight variance for judge scoring; 0.1 keeps outputs stable but not frozen
JUDGE_TEMPERATURE=0.1

# ── Pipeline ──────────────────────────────────────────────────────────────────
# Number of parallel workers for CV extraction and judge phases
# Lower this if Ollama OOMs under concurrent requests
MAX_PARALLEL_WORKERS=4

# ── Evaluation ────────────────────────────────────────────────────────────────
# Cosine similarity cutoff for hallucination classification:
#   ≥ threshold → "inferred" (semantically present, not verbatim)
#   < threshold → "fabricated"
HALLUCINATION_SIMILARITY_THRESHOLD=0.85

# Scores within ±N points of the pool mean are candidates for Phase 5 calibration
BORDERLINE_SCORE_THRESHOLD=5.0

# Minimum canonical skills to accept a CV profile as valid
MIN_PROFILE_SKILLS=3

# Sentence-Transformers model used for evidence verification (runs locally)
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ── Langfuse ──────────────────────────────────────────────────────────────────
# Get keys from https://cloud.langfuse.com → Settings → API Keys
# For self-hosted: set LANGFUSE_HOST to your instance URL (e.g. http://localhost:3000)
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_HOST=https://cloud.langfuse.com

# ── OpenTelemetry ─────────────────────────────────────────────────────────────
OTEL_SERVICE_NAME=evidencerank
OTEL_SERVICE_VERSION=0.1.0

# Langfuse accepts OTLP traces at /api/public/otel
# Auth: Basic base64(PUBLIC_KEY:SECRET_KEY) — compute once and paste below
# Alternatively redirect to Jaeger/Tempo by changing this endpoint
OTEL_EXPORTER_OTLP_ENDPOINT=https://cloud.langfuse.com/api/public/otel

# Kill switch — set to "false" for offline runs, CI, or unit tests
TELEMETRY_ENABLED=true
