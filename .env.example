# ── Ollama ────────────────────────────────────────────────────────────────────
# Extraction agents: JD parser (Phase 1) and CV extractor (Phase 2)
# Recommended: qwen2.5:7b  |  Minimum VRAM: ~6 GB
SMALL_MODEL=qwen2.5:7b

# Judge (Phase 3) + pool calibrator (Phase 4) — reasoning-heavy
# Recommended: llama3.3:70b  |  Minimum VRAM: ~48 GB (or use Q4 quant)
LARGE_MODEL=llama3.3:70b

# ── LLM tuning ────────────────────────────────────────────────────────────────
# 0.0 = fully deterministic; keep extraction at 0 for reproducibility
EXTRACTION_TEMPERATURE=0.0

# Slight variance for judge scoring; 0.1 keeps outputs stable but not frozen
JUDGE_TEMPERATURE=0.1

# ── Evaluation ────────────────────────────────────────────────────────────────
# Scores within ±N points of the pool mean are candidates for Phase 4 calibration
BORDERLINE_SCORE_THRESHOLD=5.0

# Sentence-Transformers model used for embeddings (skill matching + hallucination checker)
# Downloaded automatically from HuggingFace on first run
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ── Skill matching ────────────────────────────────────────────────────────────
# Minimum cosine similarity for a candidate skill to satisfy a required JD skill.
# Candidates with no required-skill match above this threshold are eliminated
# before Phase 3 (saves LLM calls).
SKILL_MATCH_THRESHOLD=0.75

# ── Langfuse ──────────────────────────────────────────────────────────────────
# Get keys from https://cloud.langfuse.com → Settings → API Keys
# For self-hosted: set LANGFUSE_HOST to your instance URL (e.g. http://localhost:3000)
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_HOST=https://cloud.langfuse.com

# ── OpenTelemetry ─────────────────────────────────────────────────────────────
OTEL_SERVICE_NAME=evidencerank
OTEL_SERVICE_VERSION=0.1.0 

# Kill switch — set to "false" for offline runs, CI, or unit tests
TELEMETRY_ENABLED=true

# ── HuggingFace ───────────────────────────────────────────────────────────────
# Optional — avoids unauthenticated rate limits when downloading EMBEDDING_MODEL
HF_TOKEN=hf_