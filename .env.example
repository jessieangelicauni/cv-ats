# ── Ollama ────────────────────────────────────────────────────────────────────
# Extraction agents: JD parser (Phase 1) and CV extractor (Phase 2)
# Recommended: qwen2.5:7b  |  Minimum VRAM: ~6 GB
SMALL_MODEL=qwen2.5:7b

# Judge (Phase 3) + pool calibrator (Phase 4) — reasoning-heavy
# Recommended: qwen3:14b  |  Minimum VRAM: ~48 GB (or use Q4 quant)
LARGE_MODEL=qwen3:14b

# ── LLM tuning ────────────────────────────────────────────────────────────────
# 0.0 = fully deterministic; keep extraction at 0 for reproducibility
EXTRACTION_TEMPERATURE=0.0

# Slight variance for judge scoring; 0.1 keeps outputs stable but not frozen
JUDGE_TEMPERATURE=0.1

# ── Evaluation ────────────────────────────────────────────────────────────────
# Sentence-Transformers model used for embeddings (skill matching + hallucination checker)
# Downloaded automatically from HuggingFace on first run
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ── HuggingFace ───────────────────────────────────────────────────────────────
# Optional — avoids unauthenticated rate limits when downloading EMBEDDING_MODEL
HF_TOKEN=hf_
